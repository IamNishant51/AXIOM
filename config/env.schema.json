{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Axiom Environment Configuration",
  "type": "object",
  "properties": {
    "OPENCODE_API_KEY": {
      "type": "string",
      "description": "OpenCode API key for model access"
    },
    "ANTHROPIC_API_KEY": {
      "type": "string",
      "description": "Anthropic API key for Claude models"
    },
    "OPENAI_API_KEY": {
      "type": "string",
      "description": "OpenAI API key for GPT models"
    },
    "GEMINI_API_KEY": {
      "type": "string",
      "description": "Google Gemini API key"
    },
    "GROQ_API_KEY": {
      "type": "string",
      "description": "Groq API key for Llama models"
    },
    "XAI_API_KEY": {
      "type": "string",
      "description": "xAI API key for Grok models"
    },
    "CEREBRAS_API_KEY": {
      "type": "string",
      "description": "Cerebras API key for Llama models"
    },
    "AXIOM_CONFIG_DIR": {
      "type": "string",
      "default": "~/.axiom",
      "description": "Configuration directory path"
    },
    "AXIOM_DB_PATH": {
      "type": "string",
      "description": "Custom SQLite database path"
    },
    "AXIOM_LOG_LEVEL": {
      "type": "string",
      "enum": ["debug", "info", "warn", "error"],
      "default": "info",
      "description": "Log level"
    },
    "AXIOM_SECURE_MODE": {
      "type": "boolean",
      "default": false,
      "description": "Enable secure mode with command restrictions"
    },
    "AXIOM_ALLOW_SHELL": {
      "type": "boolean",
      "default": true,
      "description": "Allow shell command execution"
    }
  }
}