{
  "version": "1.0",
  "description": "Allowed shell commands for Axiom",
  "allowlist": [
    "ls", "la", "ll", "dir", "stat",
    "cat", "head", "tail", "wc", "grep", "rg", "find",
    "cd", "pwd", "mkdir", "rmdir", "touch", "rm", "cp", "mv",
    "chmod", "chown", "ln", "readlink",
    "git", "gh",
    "node", "npm", "pnpm", "yarn", "bun",
    "python", "python3", "pip", "pip3",
    "cargo", "rustc", "go", "java", "javac",
    "gcc", "g++", "clang", "make", "cmake",
    "ps", "kill", "killall", "top", "htop",
    "df", "du", "free", "uname",
    "curl", "wget", "ping", "ssh", "scp",
    "tar", "gzip", "gunzip", "zip", "unzip",
    "sed", "awk", "sort", "uniq", "cut", "tr", "tee",
    "jq", "yq", "rg", "fzf"
  ],
  "dangerousCommands": [
    "rm", "del", "format",
    "shutdown", "reboot", "halt",
    "dd", "fdisk", "mkfs"
  ],
  "blockedCommands": [
    "sudo", "su",
    "eval", "exec",
    "base64"
  ],
  "maxArgsPerCommand": 50,
  "maxCommandLength": 10000,
  "rateLimit": {
    "maxCalls": 20,
    "windowMs": 60000
  }
}